#version 460

#extension GL_GOOGLE_include_directive : require

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(set = 0, binding = 0) uniform U_SunInfo {
    vec3 sun_dir;
    float sun_size;
    vec3 sun_color;
    float sun_luminance;
    float sun_display_luminance;
    float sun_altitude;
    float sun_azimuth;
}
sun_info;

layout(set = 0, binding = 1) uniform U_CameraInfo {
    vec4 pos;
    mat4 view_mat;
    mat4 view_mat_inv;
    mat4 proj_mat;
    mat4 proj_mat_inv;
    mat4 view_proj_mat;
    mat4 view_proj_mat_inv;
}
camera_info;

layout(set = 0, binding = 2, r32f) uniform readonly image2D gfx_depth_tex;
layout(set = 0, binding = 3) uniform sampler2D sun_sprite_tex;
layout(set = 0, binding = 4, r32ui) uniform uimage1D lens_flare_required_count_tex;

#include "../include/ray.glsl"

float sample_sun_alpha(vec2 screen_uv) {
    Ray ray = ray_gen(screen_uv, camera_info.view_proj_mat_inv);
    vec3 view_dir = normalize(ray.direction);

    if (dot(view_dir, sun_info.sun_dir) <= 0.0) {
        return 0.0;
    }

    vec3 view_dir_vs = normalize((camera_info.view_mat * vec4(view_dir, 0.0)).xyz);
    vec3 sun_dir_vs  = normalize((camera_info.view_mat * vec4(sun_info.sun_dir, 0.0)).xyz);
    float view_z = -view_dir_vs.z;
    float sun_z  = -sun_dir_vs.z;
    if (view_z <= 1e-5 || sun_z <= 1e-5) {
        return 0.0;
    }

    vec2 view_proj = view_dir_vs.xy / view_z;
    vec2 sun_proj  = sun_dir_vs.xy / sun_z;
    vec2 uv        = (view_proj - sun_proj) / max(sun_info.sun_size, 0.0001) + vec2(0.5);
    if (any(lessThan(uv, vec2(0.0))) || any(greaterThan(uv, vec2(1.0)))) {
        return 0.0;
    }

    return texture(sun_sprite_tex, uv).a;
}

void main() {
    ivec2 uvi = ivec2(gl_GlobalInvocationID.xy);
    ivec2 img_size = imageSize(gfx_depth_tex);
    if (any(greaterThanEqual(uvi, img_size))) {
        return;
    }

    vec2 screen_uv = (vec2(uvi) + vec2(0.5)) / vec2(img_size);
    float alpha = sample_sun_alpha(screen_uv);
    if (alpha > 0.001) {
        imageAtomicAdd(lens_flare_required_count_tex, 0, 1u);
    }
}
