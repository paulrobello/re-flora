#version 460

#extension GL_GOOGLE_include_directive : require

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(set = 0, binding = 0) uniform U_GuiInput {
    float debug_float;
    uint debug_bool;
    uint debug_uint;
    vec3 flora_instance_hsv_offset_max;
    vec3 flora_voxel_hsv_offset_max;
    vec3 grass_bottom_dark;
    vec3 grass_bottom_light;
    vec3 grass_tip_dark;
    vec3 grass_tip_light;
    vec3 ocean_deep_color;
    vec3 ocean_shallow_color;
    float ocean_normal_amplitude;
    float ocean_noise_frequency;
    float ocean_time_multiplier;
    float ocean_sea_level_shift;
    uint flora_update_bucket_count;
    float flora_full_update_seconds;
    float lens_flare_intensity;
    float lens_flare_sun_pixel_scale;
}
gui_input;
layout(set = 0, binding = 1) uniform U_SunInfo {
    vec3 sun_dir;
    float sun_size;
    vec3 sun_color;
    float sun_luminance;
    float sun_display_luminance;
    float sun_altitude;
    float sun_azimuth;
}
sun_info;
layout(set = 0, binding = 2) uniform U_CameraInfo {
    vec4 pos;
    mat4 view_mat;
    mat4 view_mat_inv;
    mat4 proj_mat;
    mat4 proj_mat_inv;
    mat4 view_proj_mat;
    mat4 view_proj_mat_inv;
}
camera_info;
layout(set = 0, binding = 4, r32ui) uniform readonly uimage1D lens_flare_visible_count_tex;
layout(set = 0, binding = 5, r11f_g11f_b10f) uniform writeonly image2D lens_flare_full_output_tex;

#include "../include/core/hash.glsl"
#include "../include/sunlight.glsl"

float _lens_flare_noise(float t) { return hash11(t); }

float _lens_flare_noise(vec2 t) { return hash_12(t); }

vec3 _lens_flare_pattern(vec2 uv, vec2 pos) {
    vec2 main = uv - pos;
    vec2 uvd  = uv * length(uv);

    float ang  = atan(main.x, main.y);
    float dist = pow(length(main), 0.1);
    float n    = _lens_flare_noise(vec2(ang * 16.0, dist * 32.0));

    float f0 = 1.0 / (length(uv - pos) * 16.0 + 1.0);
    f0 +=
        f0 * (sin(_lens_flare_noise(sin(ang * 2.0 + pos.x) * 4.0 - cos(ang * 3.0 + pos.y)) * 16.0) *
                  0.1 +
              dist * 0.1 + 0.8);

    float f1 = max(0.01 - pow(length(uv + 1.2 * pos), 1.9), 0.0) * 7.0;

    float f2  = max(1.0 / (1.0 + 32.0 * pow(length(uvd + 0.8 * pos), 2.0)), 0.0) * 0.25;
    float f22 = max(1.0 / (1.0 + 32.0 * pow(length(uvd + 0.85 * pos), 2.0)), 0.0) * 0.23;
    float f23 = max(1.0 / (1.0 + 32.0 * pow(length(uvd + 0.9 * pos), 2.0)), 0.0) * 0.21;

    vec2 uvx = mix(uv, uvd, -0.5);

    float f4  = max(0.01 - pow(length(uvx + 0.4 * pos), 2.4), 0.0) * 6.0;
    float f42 = max(0.01 - pow(length(uvx + 0.45 * pos), 2.4), 0.0) * 5.0;
    float f43 = max(0.01 - pow(length(uvx + 0.5 * pos), 2.4), 0.0) * 3.0;

    uvx = mix(uv, uvd, -0.4);

    float f5  = max(0.01 - pow(length(uvx + 0.2 * pos), 5.5), 0.0) * 2.0;
    float f52 = max(0.01 - pow(length(uvx + 0.4 * pos), 5.5), 0.0) * 2.0;
    float f53 = max(0.01 - pow(length(uvx + 0.6 * pos), 5.5), 0.0) * 2.0;

    uvx = mix(uv, uvd, -0.5);

    float f6  = max(0.01 - pow(length(uvx - 0.3 * pos), 1.6), 0.0) * 6.0;
    float f62 = max(0.01 - pow(length(uvx - 0.325 * pos), 1.6), 0.0) * 3.0;
    float f63 = max(0.01 - pow(length(uvx - 0.35 * pos), 1.6), 0.0) * 5.0;

    vec3 c = vec3(0.0);
    c.r += f2 + f4 + f5 + f6;
    c.g += f22 + f42 + f52 + f62;
    c.b += f23 + f43 + f53 + f63;
    c = c * 1.3 - vec3(length(uvd) * 0.05);
    c += vec3(f0 * 0.22 + f1 * 0.25 + n * 0.02);

    return c;
}

vec3 _lens_flare_color_correct(vec3 color, float factor, float factor2) {
    float w = color.x + color.y + color.z;
    return mix(color, vec3(w) * factor, w * factor2);
}

void main() {
    ivec2 uvi             = ivec2(gl_GlobalInvocationID.xy);
    ivec2 lens_flare_size = imageSize(lens_flare_full_output_tex);
    if (any(greaterThanEqual(uvi, lens_flare_size))) {
        return;
    }

    vec2 lens_flare_uv = (vec2(uvi) + vec2(0.5)) / vec2(lens_flare_size);

    vec3 sun_world_pos = camera_info.pos.xyz + sun_info.sun_dir * 10000.0;
    vec4 sun_clip_pos  = camera_info.view_proj_mat * vec4(sun_world_pos, 1.0);
    if (sun_clip_pos.w <= 0.0) {
        imageStore(lens_flare_full_output_tex, uvi, vec4(0.0));
        return;
    }

    vec2 sun_uv                  = (sun_clip_pos.xy / sun_clip_pos.w) * 0.5 + 0.5;
    vec2 sun_uv_dist_from_center = abs(sun_uv - vec2(0.5));
    float edge_factor =
        1.0 - smoothstep(0.45, 0.8, max(sun_uv_dist_from_center.x, sun_uv_dist_from_center.y));
    if (edge_factor <= 0.0) {
        imageStore(lens_flare_full_output_tex, uvi, vec4(0.0));
        return;
    }

    uint visible_count = imageLoad(lens_flare_visible_count_tex, 0).r;
    if (visible_count == 0u) {
        imageStore(lens_flare_full_output_tex, uvi, vec4(0.0));
        return;
    }

    float sun_radius_px = 0.5 * max(sun_info.sun_size, 0.0001) * camera_info.proj_mat[1][1] *
                          float(lens_flare_size.y);
    float estimated_total_pixels =
        gui_input.lens_flare_sun_pixel_scale * 3.14159265 * sun_radius_px * sun_radius_px;
    float visible_ratio = clamp(float(visible_count) / max(estimated_total_pixels, 1.0), 0.0, 1.0);

    vec2 uv      = lens_flare_uv - vec2(0.5);
    vec2 pos     = sun_uv - vec2(0.5);
    float aspect = float(lens_flare_size.x) / float(lens_flare_size.y);
    uv.x *= aspect;
    pos.x *= aspect;

    vec3 flare = vec3(1.4, 1.2, 1.0) * _lens_flare_pattern(uv, pos);
    flare      = _lens_flare_color_correct(flare, 0.5, 0.1);

    float sun_visibility = sun_luminance_from_dir(sun_info.sun_dir, 1.0);
    float intensity = gui_input.lens_flare_intensity * sun_visibility * edge_factor * visible_ratio;
    vec3 lens_flare_color = max(flare, vec3(0.0)) * intensity;
    imageStore(lens_flare_full_output_tex, uvi, vec4(lens_flare_color, 1.0));
}
