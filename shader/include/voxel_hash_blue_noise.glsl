uint voxel_hash_bucket_from_blue_noise(ivec3 world_pos) {
    ivec3 tiled = ivec3(world_pos.x & 31, world_pos.y & 31, world_pos.z & 31);
    uint linear = uint((tiled.z << 10) | (tiled.y << 5) | tiled.x);
    uint packed = voxel_hash_blue_noise_packed[linear >> 4u];
    uint shift  = (linear & 15u) << 1u;
    return (packed >> shift) & 0x3u;
}

